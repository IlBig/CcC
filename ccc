#!/usr/bin/env bash
# =============================================================================
# ccc — Claude Code Consulting project bootstrapper
#
# Creates a new project with the full CcC workflow structure:
# AGENTS.md, CLAUDE.md, SPEC.md, skills, hooks, settings — ready to go.
#
# Usage: ccc [project-name]
# Install: cp ccc ~/bin/ccc && chmod +x ~/bin/ccc
#          (ensure ~/bin is in your PATH)
# =============================================================================

set -euo pipefail

# --- Configuration ---
CCC_REPO="${CCC_REPO:-https://github.com/IlBig/CcC.git}"

# --- Colors ---
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

# --- Helpers ---
info()    { echo -e "${CYAN}[ccc]${NC} $*"; }
success() { echo -e "${GREEN}[ccc]${NC} $*"; }
warn()    { echo -e "${YELLOW}[ccc]${NC} $*"; }
error()   { echo -e "${RED}[ccc]${NC} $*" >&2; exit 1; }

# --- Cleanup trap ---
TEMP_DIR=""
cleanup() {
    if [ -n "$TEMP_DIR" ] && [ -d "$TEMP_DIR" ]; then
        rm -rf "$TEMP_DIR"
    fi
}
trap cleanup EXIT

# =============================================================================
# Step 1: Check and install prerequisites
# =============================================================================

# Check git
if ! command -v git &>/dev/null; then
    info "Git not found. Installing Xcode Command Line Tools..."
    xcode-select --install 2>/dev/null || true
    error "Please wait for Xcode CLT installation to complete, then run ccc again."
fi

# Check npm (needed for claude and codex)
if ! command -v npm &>/dev/null; then
    error "Node.js/npm required but not found. Install from https://nodejs.org/"
fi

# Check / install Claude Code CLI
if ! command -v claude &>/dev/null; then
    info "Claude Code CLI not found. Installing..."
    npm install -g @anthropic-ai/claude-code || error "Failed to install Claude Code CLI."
    success "Claude Code CLI installed."
    info "Launching Claude Code for first-time login..."
    claude --version
    info "If you need to log in, Claude Code will prompt you on first launch."
fi

# Check / install Codex CLI
if ! command -v codex &>/dev/null; then
    info "Codex CLI not found. Installing..."
    npm install -g @openai/codex || error "Failed to install Codex CLI."
    success "Codex CLI installed."
    info "Running Codex login..."
    codex login || warn "Codex login failed or was skipped. You can run 'codex login' later."
fi

# =============================================================================
# Step 2: Get project name
# =============================================================================

PROJECT_NAME="${1:-}"

if [ -z "$PROJECT_NAME" ]; then
    echo -en "${CYAN}[ccc]${NC} Project name: "
    read -r PROJECT_NAME
fi

# Validate project name
if [ -z "$PROJECT_NAME" ]; then
    error "Project name cannot be empty."
fi

if ! [[ "$PROJECT_NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    error "Invalid project name '$PROJECT_NAME'. Use only letters, numbers, hyphens, and underscores."
fi

# Check if directory already exists
if [ -d "./$PROJECT_NAME" ]; then
    error "Directory ./$PROJECT_NAME already exists. Aborting."
fi

# =============================================================================
# Step 2b: Ask conversation language
# =============================================================================

OS_LOCALE=$(defaults read -g AppleLocale 2>/dev/null || echo "${LANG:-en}" | cut -d. -f1)
if [ -n "${CCC_LANG:-}" ]; then
    USER_LANG="$CCC_LANG"
elif [ -t 0 ]; then
    echo -en "${CYAN}[ccc]${NC} Conversation language [$OS_LOCALE]: "
    read -r USER_LANG
    USER_LANG="${USER_LANG:-$OS_LOCALE}"
else
    USER_LANG="$OS_LOCALE"
fi

CAN_INITIAL_COMMIT=1
if ! git config --get user.name >/dev/null 2>&1 || ! git config --get user.email >/dev/null 2>&1; then
    CAN_INITIAL_COMMIT=0
    warn "Git user.name/user.email not configured. The project will be created, but the initial commit will be skipped."
fi

# =============================================================================
# Step 3: Clone workflow repo to temp directory
# =============================================================================

info "Cloning workflow repo..."
TEMP_DIR=$(mktemp -d)
SRC="$TEMP_DIR/ccc-source"

git clone --quiet --depth 1 "$CCC_REPO" "$SRC" || error "Failed to clone $CCC_REPO. Check your internet connection."

# Verify key files exist
if [ ! -f "$SRC/templates/AGENTS.md.template" ]; then
    error "Workflow repo is missing expected files. Check $CCC_REPO is correct."
fi

# =============================================================================
# Step 4: Create project structure
# =============================================================================

info "Creating project '$PROJECT_NAME'..."

mkdir "./$PROJECT_NAME"
cd "./$PROJECT_NAME"
git init --quiet

# --- Create directories ---
mkdir -p .claude/skills/spec
mkdir -p .claude/skills/research
mkdir -p .claude/skills/review
mkdir -p .claude/skills/notes
mkdir -p .claude/skills/continue
mkdir -p .claude/skills/update
mkdir -p hooks

# --- Copy and transform templates ---
sed "s|\[Project Name\]|$PROJECT_NAME|g; s|\[Conversation Language\]|$USER_LANG|g" "$SRC/templates/AGENTS.md.template" > AGENTS.md
cp "$SRC/templates/CLAUDE.md.template" CLAUDE.md
sed "s|\[Project Name\]|$PROJECT_NAME|g" "$SRC/templates/SPEC.md.template" > SPEC.md
sed "s|\[Project Name\]|$PROJECT_NAME|g" "$SRC/templates/IMPLEMENTATION_NOTES.md.template" > IMPLEMENTATION_NOTES.md

# --- Copy skills ---
cp "$SRC/skills/spec/SKILL.md"     .claude/skills/spec/SKILL.md
cp "$SRC/skills/research/SKILL.md" .claude/skills/research/SKILL.md
cp "$SRC/skills/review/SKILL.md"   .claude/skills/review/SKILL.md
cp "$SRC/skills/notes/SKILL.md"    .claude/skills/notes/SKILL.md
cp "$SRC/skills/continue/SKILL.md" .claude/skills/continue/SKILL.md
cp "$SRC/skills/update/SKILL.md"   .claude/skills/update/SKILL.md

# --- Install hooks ---
cp "$SRC/hooks/pre-commit-review.sh" .git/hooks/pre-commit
chmod +x .git/hooks/pre-commit
cp "$SRC/hooks/pre-compaction.sh" hooks/pre-compaction.sh
chmod +x hooks/pre-compaction.sh

# --- Generate .claude/settings.json ---
cat > .claude/settings.json <<'EOF'
{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/hooks/pre-compaction.sh",
            "statusMessage": "Saving implementation notes before compaction..."
          }
        ]
      }
    ]
  }
}
EOF

# --- Generate .gitignore ---
cat > .gitignore <<'EOF'
# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.vscode/
.idea/

# Environment
.env
.env.local

# Workflow artifacts
REVIEW.md
.claude/auto-memory/
.claude/sessions/
EOF

# =============================================================================
# Step 5: Cleanup temp directory
# =============================================================================

rm -rf "$TEMP_DIR"
TEMP_DIR=""

# =============================================================================
# Step 6: Initial commit
# =============================================================================

if [ "$CAN_INITIAL_COMMIT" -eq 1 ]; then
    git add -A
    git commit --quiet --no-verify -m "chore: bootstrap project with CcC workflow"
else
    warn "Skipping initial commit. Configure git user.name and user.email, then commit the bootstrap files."
fi

# =============================================================================
# Step 7: Summary and launch
# =============================================================================

echo ""
success "Project '$PROJECT_NAME' created successfully!"
echo ""
info "Structure:"
echo "  AGENTS.md               — AI instruction file (primary, read by Codex + Claude)"
echo "  CLAUDE.md               — Redirect to AGENTS.md (for Claude Code)"
echo "  SPEC.md                 — Project specification template"
echo "  IMPLEMENTATION_NOTES.md — Session diary"
echo "  .claude/skills/         — Workflow skills (6)"
echo "  .claude/settings.json   — PreCompact hook config"
echo "  .git/hooks/pre-commit   — Codex auto-review hook"
echo "  hooks/pre-compaction.sh — PreCompact handler"
echo "  .gitignore              — OS, editors, env files"
echo ""
info "Launching Claude Code..."
info "Tip: run /spec to start defining your project specification."
echo ""

exec claude --dangerously-skip-permissions
